{
  "name": "pi-model-modes",
  "version": "0.3.0",
  "description": "A pi extension that adapts the system prompt per model/mode.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "files": [
    "extensions/",
    "src/",
    "prompts/",
    "presets.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "^0.79.9",
    "@types/node": "^22.19.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
